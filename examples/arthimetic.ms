# Basic arithmetic operations

let a = 20
let b = 6

let sum = a + b
let diff = a - b
let product = a * b
let quotient = a / b

print "Sum:"
print sum

print "Difference:"
print diff

print "Product:"
print product

print "Quotient:"
print quotient

# Operator precedence
let expr = (a + b) * 2 - b / 2
print "Expression result:"
print expr